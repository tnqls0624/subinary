{
  "name": "@family/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Family Memory AI — BullMQ worker service (NestJS 11 + Fastify 5, port 3002)",
  "scripts": {
    "dev": "nest build -b swc && concurrently -k -n build,run -c blue,green \"nest build -b swc --watch --preserveWatchOutput\" \"nodemon\"",
    "build": "nest build -b swc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo noop"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@family/ai-providers": "workspace:*",
    "@family/card-parsers": "workspace:*",
    "@family/config": "workspace:*",
    "@family/database": "workspace:*",
    "@family/rag": "workspace:*",
    "@family/shared": "workspace:*",
    "@family/slack-parser": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.10.4",
    "@types/node": "^22.10.5",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}

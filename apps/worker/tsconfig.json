{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // module/moduleResolution은 base(NodeNext) 상속 — package.json에 type 필드가
    // 없어 CJS로 판정되므로 NestJS(CJS)와 정합하고, 구식 node10/baseUrl 조합의 TS 6/7 deprecation 경고를 원천 제거한다.
    // 주의: rootDir을 명시하면 nest swc 빌더가 dist/src/ 레이아웃으로 emit해
    // dist/main.js 실행 경로가 깨진다 — 명시하지 말 것. 실제 빌드는 swc(nest -b swc)라
    // 이 파일은 typecheck/IDE 전용이다.
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

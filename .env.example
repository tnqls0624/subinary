# --- App ---
NODE_ENV=development
TZ=Asia/Seoul
API_PORT=3001
WORKER_PORT=3002
WEB_PORT=3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=family
POSTGRES_PASSWORD=change_me  # openssl rand -hex 16
POSTGRES_DB=family_memory
# 앱이 사용하는 연결 문자열(컨테이너 내부 네트워크 기준)
DATABASE_URL=postgresql://family:change_me@postgres:5432/family_memory

# --- Redis / BullMQ ---
REDIS_HOST=redis
REDIS_PORT=6379
BULLMQ_PREFIX=fma

# --- Object Storage (MinIO=S3 호환) ---
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=change_me  # openssl rand -hex 16
STORAGE_BUCKET=family-memory
STORAGE_FORCE_PATH_STYLE=true

# --- Web (브라우저에서 API 접근; 호스트 published 포트) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
# API가 허용하는 웹 오리진(CORS). refresh 쿠키 전송을 위해 credentials 허용.
# 네이티브(Capacitor) origin(capacitor://localhost, http(s)://localhost)은 API가
# 코드로 추가 허용한다(apps/api/src/main.ts) → 여기엔 웹 origin만 두면 된다.
CORS_ORIGIN=http://localhost:3000
# 모바일(Capacitor) 빌드는 NEXT_PUBLIC_API_URL을 빌드 시점에 인라인한다.
#   NEXT_PUBLIC_API_URL=https://api.your-domain.com pnpm --filter @family/web build:mobile
# 실기기 테스트 시 localhost 대신 맥의 LAN IP를 쓴다(기기 입장의 localhost는 자기 자신).

# --- AI Providers (Phase 0는 mock) ---
# mock(기본) | gemini | openai | anthropic — gemini는 GEMINI_API_KEY 필요(없으면 mock 폴백)
AI_PROVIDER=mock
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Auth (Phase 1) ---
# 개발용 더미 시크릿(16자+). 운영에서는 반드시 교체할 것.
JWT_ACCESS_SECRET=change_me  # openssl rand -hex 32
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- Device (Phase 2) ---
# 장치 Secret at-rest 암호화 키. 정확히 64자 hex(=32바이트) 개발용 더미. 운영에서는 반드시 교체할 것.
DEVICE_SECRET_ENC_KEY=change_me  # 정확히 64자 hex: openssl rand -hex 32
# HMAC 타임스탬프 허용 오차(초)
HMAC_TIMESTAMP_TOLERANCE_SEC=300
# Nonce 재사용 방지 저장 TTL(초)
DEVICE_NONCE_TTL_SEC=600
# mobile-events 요청 본문 최대 바이트(Fastify bodyLimit)
MOBILE_MAX_BODY_BYTES=16384

# --- MCP (Phase 10, Claude Code가 주입) ---
# stdio MCP 서버(apps/mcp)는 compose 서비스가 아니며, Claude Code/Cursor가
# `node apps/mcp/dist/main.js` 를 실행하면서 아래 env 를 주입한다.
# 아래 값은 예시일 뿐이며, 실제 실행 시 Claude Code MCP 설정에서 주입한다.
# FAMILY_API_URL: 도구가 호출할 API 베이스 URL(기본 http://localhost:3001)
FAMILY_API_URL=http://localhost:3001
# FAMILY_EMAIL / FAMILY_PASSWORD: 로그인 계정(access token + refresh 쿠키 획득). 커밋 금지.
FAMILY_EMAIL=
FAMILY_PASSWORD=
# FAMILY_WORKSPACE_ID: 미지정 시 GET /v1/slack/workspaces 첫 워크스페이스 자동 사용
FAMILY_WORKSPACE_ID=
# FAMILY_HOUSEHOLD_ID: 미지정 시 GET /v1/auth/me memberships 첫 가구 자동 사용
FAMILY_HOUSEHOLD_ID=

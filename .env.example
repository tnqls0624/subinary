# --- App ---
NODE_ENV=development
TZ=Asia/Seoul
API_PORT=3001
WORKER_PORT=3002
WEB_PORT=3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=family
POSTGRES_PASSWORD=change_me  # openssl rand -hex 16
POSTGRES_DB=family_memory
# 앱이 사용하는 연결 문자열(컨테이너 내부 네트워크 기준)
DATABASE_URL=postgresql://family:change_me@postgres:5432/family_memory

# --- Redis / BullMQ ---
REDIS_HOST=redis
REDIS_PORT=6379
BULLMQ_PREFIX=fma

# --- Object Storage (MinIO=S3 호환) ---
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=change_me  # openssl rand -hex 16
STORAGE_BUCKET=family-memory
STORAGE_FORCE_PATH_STYLE=true

# --- 운영 논리 백업 (docker-compose.prod.yml의 backup 서비스) ---
# 호스트의 암호화된 디스크 경로를 권장한다. 상대 경로는 프로젝트 디렉터리 기준이다.
BACKUP_DIR=./backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETRY_SECONDS=300
BACKUP_RETENTION_DAYS=30

# --- 맥 외부 암호화 백업 복제 (restic, docker profile: offsite-backup) ---
# 예: s3:https://s3.example.com/subinary-backup 또는 rest:https://backup.example.com/subinary
RESTIC_REPOSITORY=
# 분실 시 원격 백업을 복구할 수 없다. 운영 secret으로만 보관한다.
RESTIC_PASSWORD=
# S3 호환 저장소일 때만 설정한다.
RESTIC_AWS_ACCESS_KEY_ID=
RESTIC_AWS_SECRET_ACCESS_KEY=
RESTIC_AWS_DEFAULT_REGION=us-east-1
# REST backend 인증이 필요할 때 URL에 비밀번호를 넣지 않고 사용한다.
RESTIC_REST_USERNAME=
RESTIC_REST_PASSWORD=
BACKUP_REPLICA_INTERVAL_SECONDS=86400
BACKUP_REPLICA_RETRY_SECONDS=300
BACKUP_REPLICA_KEEP_DAILY=30
BACKUP_REPLICA_KEEP_WEEKLY=12
BACKUP_REPLICA_KEEP_MONTHLY=12
BACKUP_REPLICA_CHECK_INTERVAL_DAYS=30

# --- 별도 Training Runner (docker profile: training) ---
# API에서 생성한 run UUID를 명령에만 주입한다. .env에 고정 저장하지 않는다.
# TRAINING_RUN_ID=<uuid> pnpm ops:training:run

# --- Web (브라우저에서 API 접근; 호스트 published 포트) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
# 초대 링크 등 밖으로 공유되는 절대 URL의 베이스(공개 웹 도메인).
# 미설정 시 web은 window.location.origin fallback — 브라우저 접속은 문제없지만
# Capacitor 앱 origin은 localhost라 앱에서 링크를 만들려면 반드시 설정해야 한다.
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# API가 허용하는 웹 오리진(CORS). refresh 쿠키 전송을 위해 credentials 허용.
# 네이티브(Capacitor) origin(capacitor://localhost, http(s)://localhost)은 API가
# 코드로 추가 허용한다(apps/api/src/main.ts) → 여기엔 웹 origin만 두면 된다.
CORS_ORIGIN=http://localhost:3000
# 모바일(Capacitor) 빌드는 NEXT_PUBLIC_API_URL/NEXT_PUBLIC_WEB_URL을 빌드 시점에 인라인한다.
#   NEXT_PUBLIC_API_URL=https://api.your-domain.com \
#   NEXT_PUBLIC_WEB_URL=https://app.your-domain.com \
#     pnpm --filter @family/web build:mobile
# 실기기 테스트 시 localhost 대신 맥의 LAN IP를 쓴다(기기 입장의 localhost는 자기 자신).

# --- AI Providers (Phase 0는 mock) ---
# mock(개발 기본) | gemini | openai | anthropic
# production은 strict 모드라 mock/키 누락/미구현 provider로 시작하지 않는다.
# 현재 production LLM 경로는 gemini + GEMINI_API_KEY를 사용한다.
AI_PROVIDER=mock
# production alias가 준비된 뒤 true로 전환한다. 미설정/false는 alias가 없을 때 현재 구성을 사용한다.
AI_MODEL_ALIAS_REQUIRED=false
# post-promotion canary를 API 제어 평면에서 주기 평가한다.
AI_MODEL_CANARY_MONITOR_ENABLED=false
AI_MODEL_CANARY_MONITOR_INTERVAL_MS=30000
AI_MODEL_CANARY_MONITOR_BATCH_SIZE=50
# --- AI pipeline operational alerts ---
# 미설정이면 실패/격리/rollback 알림은 DB outbox에 보존되고 외부 발송만 멈춘다.
# 운영 URL은 HTTPS를 권장한다. generic은 operational-alert-v1 JSON, slack은 Incoming Webhook 형식이다.
# PIPELINE_ALERT_WEBHOOK_URL=https://hooks.example.com/...
# PIPELINE_ALERT_WEBHOOK_BEARER_TOKEN=
PIPELINE_ALERT_WEBHOOK_FORMAT=generic
PIPELINE_ALERT_POLL_INTERVAL_MS=30000
PIPELINE_ALERT_BATCH_SIZE=20
PIPELINE_ALERT_REQUEST_TIMEOUT_MS=5000
PIPELINE_ALERT_MAX_ATTEMPTS=8
# 후보 embedding을 backfill할 때 registry의 version과 같은 revision을 지정한다.
# AI_EMBEDDING_MODEL=text-embedding-3-small
# AI_EMBEDDING_MODEL_REVISION=text-embedding-3-small-2026-07
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# shadow/live 후보 LLM은 provider/model/revision 세 identity를 함께 설정한다.
# 후보 credential을 생략하면 기본 GEMINI_API_KEY를 재사용한다.
# AI_CANDIDATE_PROVIDER=gemini
# AI_CANDIDATE_LLM_MODEL=gemini-2.5-flash-lite
# AI_CANDIDATE_LLM_MODEL_REVISION=gemini-2.5-flash-lite-2026-07
# AI_CANDIDATE_GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Auth (Phase 1) ---
# 개발용 더미 시크릿(16자+). 운영에서는 반드시 교체할 것.
JWT_ACCESS_SECRET=change_me  # openssl rand -hex 32
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000
# 모바일(Capacitor) 자동로그인 세션 TTL(초). 기본 1년 — 웹(쿠키)은 위 30일 유지.
# 모바일은 X-Client-Platform: capacitor 헤더로 식별해 이 TTL을 부여한다(로테이션마다 갱신).
JWT_REFRESH_TTL_MOBILE_SEC=31536000

# --- Device (Phase 2) ---
# 장치 Secret at-rest 암호화 키. 정확히 64자 hex(=32바이트) 개발용 더미. 운영에서는 반드시 교체할 것.
DEVICE_SECRET_ENC_KEY=change_me  # 정확히 64자 hex: openssl rand -hex 32
# HMAC 타임스탬프 허용 오차(초)
HMAC_TIMESTAMP_TOLERANCE_SEC=300
# Nonce 재사용 방지 저장 TTL(초)
DEVICE_NONCE_TTL_SEC=600
# mobile-events 요청 본문 최대 바이트(Fastify bodyLimit)
MOBILE_MAX_BODY_BYTES=16384

# --- MCP (Phase 10, Claude Code가 주입) ---
# stdio MCP 서버(apps/mcp)는 compose 서비스가 아니며, Claude Code/Cursor가
# `node apps/mcp/dist/main.js` 를 실행하면서 아래 env 를 주입한다.
# 아래 값은 예시일 뿐이며, 실제 실행 시 Claude Code MCP 설정에서 주입한다.
# FAMILY_API_URL: 도구가 호출할 API 베이스 URL(기본 http://localhost:3001)
FAMILY_API_URL=http://localhost:3001
# FAMILY_EMAIL / FAMILY_PASSWORD: 로그인 계정(access token + refresh 쿠키 획득). 커밋 금지.
FAMILY_EMAIL=
FAMILY_PASSWORD=
# FAMILY_WORKSPACE_ID: 미지정 시 GET /v1/slack/workspaces 첫 워크스페이스 자동 사용
FAMILY_WORKSPACE_ID=
# FAMILY_HOUSEHOLD_ID: 미지정 시 GET /v1/auth/me memberships 첫 가구 자동 사용
FAMILY_HOUSEHOLD_ID=

# =====================================================================
# --- 프로덕션 (docker-compose.prod.yml, 맥 홈서버 + Cloudflare Tunnel) ---
# =====================================================================
# 운영 전환 시 위 값들을 운영용으로 바꾼다:
#   NODE_ENV=production            # refresh 쿠키 Secure 활성화 + 프로덕션 런타임
#   CORS_ORIGIN=${PUBLIC_BASE_URL} # 실 도메인(아래)로
#
# 실 서비스 공개 도메인(같은 오리진: https://도메인, /v1/*는 api로 라우팅).
# web 이미지 빌드 시 NEXT_PUBLIC_API_URL로 인라인되고, CORS_ORIGIN도 이 값을 쓴다.
PUBLIC_BASE_URL=https://app.subinary.cloud
#
# Cloudflare Tunnel 토큰(Zero Trust > Networks > Tunnels에서 발급). 커밋 금지.
# 대시보드에서 이 터널의 Public Hostname을 도메인 → Service: http://caddy:80 으로 매핑.
CLOUDFLARE_TUNNEL_TOKEN=

# --- 푸시 알림 (FCM HTTP v1; 선택) ---
# 세 값이 모두 있으면 워커가 결제 승격 시 푸시를 발송하고, 하나라도 비면 no-op.
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성(JSON)에서 얻는다.
#  - FCM_PROJECT_ID  = JSON의 project_id
#  - FCM_CLIENT_EMAIL = JSON의 client_email
#  - FCM_PRIVATE_KEY  = JSON의 private_key (개행은 \n 리터럴로 한 줄에 넣는다)
# iOS는 Firebase 콘솔에 APNs 인증키를 업로드하면 FCM 한 채널로 발송된다.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
